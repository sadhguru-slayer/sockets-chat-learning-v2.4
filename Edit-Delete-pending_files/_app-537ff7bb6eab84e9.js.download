ce request\n\nloop [label: until success, color: green] {\n  Service > Service: Check availability\n}\n\nServer - Service: Data processing\nServer --\x3e Client: Data response\ndeactivate Server".trim(),a="\nusers [icon: user, color: blue] {\n  id string pk\n  displayName string\n  team_role string\n  teams string\n}\n\nteams [icon: users, color: blue] {\n  id string pk\n  name string\n}\n\nworkspaces [icon: home] {\n  id string\n  createdAt timestamp\n  folderId string\n  teamId string\n}\n\nfolders [icon: folder] {\n  id string\n  name string\n}\n\nchat [icon: message-circle, color: green] {\n  duration number\n  startedAt timestamp\n  endedAt timestamp\n  workspaceId string\n}\n\ninvite [icon: mail, color: green] {\n  inviteId string\n  type string\n  workspaceId string\n  inviterId string\n}\n\nusers.teams <> teams.id\nworkspaces.folderId > folders.id\nworkspaces.teamId > teams.id\nchat.workspaceId > workspaces.id\ninvite.workspaceId > workspaces.id\ninvite.inviterId > users.id".trim(),o="\ndirection right\n\nIssue type? [shape: oval, icon: file-text]\n\nBugPath [color: red] {\n  Bug [icon: bug, color: red]\n  Duplicate? [shape: diamond, icon: copy]\n  Mark duplicate [shape: oval, icon: copy]\n  Has repro? [shape: diamond, icon: repeat]\n  Ask for repro [shape: oval, icon: repeat]\n}\n\nFeaturePath [color: green] {\n  Feature [icon: zap, color: green]\n  Well specced? [shape: diamond, icon: check-square]\n  Can be package? [shape: diamond, icon: package]\n  Define as package [shape: oval, icon: package]\n}\n\nIssue ready to claim [shape: oval, icon: send]\n\nIssue type? > Bug\nBug > Duplicate?\nDuplicate? > Mark duplicate: Yes\nDuplicate? > Has repro?: No\nHas repro? > Issue ready to claim: Yes\nHas repro? > Ask for repro: No\nIssue type? > Feature\nFeature > Can be package?\nCan be package? > Well specced?: No\nCan be package? > Define as package: Yes\nWell specced? > Issue ready to claim: Yes".trim(),s="\nAPI gateway [icon: aws-api-gateway]\nLambda [icon: aws-lambda]\nS3 [icon: aws-simple-storage-service]\n\nVPC Subnet [icon: aws-vpc] {\n  Main Server {\n    Server [icon: aws-ec2]\n    Data [icon: aws-rds]\n  }\n\n  Queue [icon: aws-auto-scaling]\n\n  Compute Nodes [color: red] {\n    Worker1 [icon: aws-ec2]\n    Worker2 [icon: aws-ec2]\n    Worker3 [icon: aws-ec2]\n  }\n}\n\nAnalytics [icon: aws-redshift]\n\nAPI gateway > Lambda > Server > Data\nServer > Queue\nQueue > Worker1, Worker2, Worker3\nS3 < Data\nCompute Nodes > Analytics".trim(),l="\ntitle Online Order Fulfillment\n\nCustomer {\n  Need product [type: event]\n  Place order [type: activity, icon: shopping-cart]\n  Shipment received [type: event, icon: mail]\n  Order completed [type: event]\n}\n\nOnline Store {\n  Sales {\n    Verify payment [type: activity, icon: credit-card]\n    Payment approved? [type: gateway, icon: x]\n    Generate pick list [type: activity, icon: list]\n  }\n  Warehouse {\n    Pick items [type: activity, icon: box]\n    Pack & label shipment [type: activity, icon: package]\n    Ship order [type: activity, icon: truck]\n    Shipped [type: event]\n  }\n}\n\nNeed product > Place order\nPlace order --\x3e Verify payment : Order\nVerify payment > Payment approved?\nPayment approved? > Generate pick list : Yes\nPayment approved? --\x3e Order completed : Payment declined\nGenerate pick list --\x3e Pick items : Pick list\nPick items > Pack & label shipment\nPack & label shipment > Ship order\nPlace order > Shipment received\nShip order --\x3e Shipment received : Shipment\nShip order > Shipped\nShipment received > Order completed\n".trim()},81226:function(e,t,n){"use strict";n.d(t,{Z:function(){return B}});var r=n(45605),a=n(87394),o=n(50930),s=n(94331),l=n(57806),u=n(6765),c=n(90581),d=n(21218),h=n(70865),f=n(96670),A=n(39309),p=n(28162),g=n(15866),m=n(35731),v=n(32819),y=n(31632),b=n(44593),w=n(15902),_=function(e){(0,d.Z)(n,e);var t=(0,A.Z)(n);function n(e){var r,a=arguments.length>1&&void 0!==arguments[1]?arguments[1]:p.r0;return(0,c.Z)(this,n